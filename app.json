{
  "expo": {
    "name": "Quran Ambience",
    "slug": "quran-ambience",
    "version": "1.0.0",
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "experiments": {
      "tsconfigPaths": true
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-status-bar"
    ],
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "backgroundColor": "#ffffff"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "backgroundColor": "#ffffff",
      "package": "com.mohdhaider07.quranambience"
    },
    "extra": {
      "eas": {
        "projectId": "9b8c89a3-5bc3-4f14-816c-5aaab651a5f1"
      }
    }
  }
}
